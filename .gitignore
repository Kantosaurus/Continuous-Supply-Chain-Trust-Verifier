# =============================================================================
# SCTV Git Ignore File
# =============================================================================

# -----------------------------------------------------------------------------
# Rust / Cargo
# -----------------------------------------------------------------------------
/target/
**/*.rs.bk
Cargo.lock.bak

# -----------------------------------------------------------------------------
# IDE and Editor Files
# -----------------------------------------------------------------------------
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# -----------------------------------------------------------------------------
# Environment and Secrets
# -----------------------------------------------------------------------------
.env
.env.local
.env.*.local
!.env.example
!.env.development

# Secrets
*.pem
*.key
*.crt
credentials.json
secrets/

# -----------------------------------------------------------------------------
# Docker
# -----------------------------------------------------------------------------
docker-compose.override.yml.local

# -----------------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------------
*.log
logs/

# -----------------------------------------------------------------------------
# Testing and Coverage
# -----------------------------------------------------------------------------
*.profraw
coverage/
tarpaulin-report.html
lcov.info

# -----------------------------------------------------------------------------
# Build Artifacts
# -----------------------------------------------------------------------------
*.pdb
dist/
build/

# -----------------------------------------------------------------------------
# Temporary Files
# -----------------------------------------------------------------------------
tmp/
temp/
*.tmp
*.bak
*.backup

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
*.db
*.sqlite
*.sqlite3

# -----------------------------------------------------------------------------
# WASM / Frontend Build
# -----------------------------------------------------------------------------
pkg/
node_modules/
