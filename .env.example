# =============================================================================
# SCTV Environment Configuration Example
# =============================================================================
# Copy this file to .env and customize for your environment.
#
# IMPORTANT: Never commit .env files with real credentials to version control!
# =============================================================================

# -----------------------------------------------------------------------------
# Database Configuration
# -----------------------------------------------------------------------------
POSTGRES_USER=sctv
POSTGRES_PASSWORD=sctv_secure_password_change_me
POSTGRES_DB=sctv
POSTGRES_PORT=5432

# Full database URL (used by services)
DATABASE_URL=postgres://sctv:sctv_secure_password_change_me@localhost:5432/sctv

# -----------------------------------------------------------------------------
# API Server Configuration
# -----------------------------------------------------------------------------
# Port to expose the API server
API_PORT=3000

# JWT secret for authentication (CHANGE IN PRODUCTION!)
SCTV_JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Enable CORS (set to false in production if not needed)
SCTV_ENABLE_CORS=true

# Log format: "json" for structured logging, "pretty" for development
SCTV_LOG_FORMAT=json

# Rust log level configuration
RUST_LOG=info,sctv_api=debug,sctv_worker=debug,tower_http=info

# -----------------------------------------------------------------------------
# Worker Configuration
# -----------------------------------------------------------------------------
# Number of concurrent worker threads
SCTV_WORKER_COUNT=4

# Job queue polling interval (milliseconds)
SCTV_POLL_INTERVAL_MS=1000

# Graceful shutdown timeout (seconds)
SCTV_SHUTDOWN_TIMEOUT_SECS=30

# -----------------------------------------------------------------------------
# Dashboard Configuration (Optional)
# -----------------------------------------------------------------------------
DASHBOARD_PORT=8080

# -----------------------------------------------------------------------------
# Email/SMTP Configuration (for notifications)
# -----------------------------------------------------------------------------
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=noreply@sctv.local

# Use TLS for SMTP connection
SMTP_TLS=true

# -----------------------------------------------------------------------------
# External Integrations (Optional)
# -----------------------------------------------------------------------------
# GitHub token for enhanced API access
GITHUB_TOKEN=

# GitLab token for integration
GITLAB_TOKEN=

# Sigstore/Fulcio for provenance verification
SIGSTORE_ENABLED=true
